    "RegisterStateDriver",
    "SetHonor",
    "SetInstanceState",
    "SetLevel",
    "SetLifetimeHKs",
    "SetMoney",
    "SetProfileIdentity",
    "SetTime",
    "SetXP",
    "SetZone",
    "SlashCmdList",
    "UIParent",
    "assertEqual",
    "assertStringMatch",
    "assert_eq",
    "assert_equal",
    "assert_false",
    "assert_near",
    "assert_true",
    "it",
    "run_tests",
  },
}

