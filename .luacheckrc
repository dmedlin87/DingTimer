std = "lua51"
codes = true
max_line_length = 120
ignore = {
  "611",
  "631",
}

read_globals = {
  "C_Timer",
  "CreateFrame",
  "DEFAULT_CHAT_FRAME",
  "GameTooltip",
  "GetCursorPosition",
  "GetHonorCurrency",
  "GetLifetimeHonorableKills",
  "GetMaxHonorCurrency",
  "GetMinimapShape",
  "GetMoney",
  "GetPVPLifetimeStats",
  "GetRealmName",
  "GetTime",
  "GetZoneText",
  "InCombatLockdown",
  "IsInInstance",
  "Minimap",
  "RegisterStateDriver",
  "UIParent",
  "UISpecialFrames",
  "UnitClass",
  "UnitLevel",
  "UnitName",
  "UnitXP",
  "UnitXPMax",
  "UnregisterStateDriver",
  "tinsert",
}

globals = {
  "DingTimerDB",
  "DingTimerMainWindow",
  "DingTimerMinimapButton",
  "DingTimerSettingsPanel",
  "DingTimerStatsPanel",
  "DingTimerXPGraphPanel",
  "SLASH_DINGTIMER1",
  "SLASH_DINGTIMER2",
  "SlashCmdList",
}

files["tests/test_*.lua"] = {
  max_line_length = false,
  globals = {
    "C_Timer",
    "ClearChatLog",
    "CreateFrame",
    "DingTimerDB",
    "DingTimerMainWindow",
    "DingTimerMinimapButton",
    "DingTimerSettingsPanel",
